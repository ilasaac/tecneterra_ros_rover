<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/touchOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:visibility="gone" />

    <!-- ── Command bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC0D1117"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnModeMenu"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="MODE: MANUAL"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <ImageButton
            android:id="@+id/btnPlannerMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_more"
            android:background="@android:color/transparent"
            android:tint="#AAFFFFFF"
            android:visibility="gone"
            android:layout_marginStart="4dp"
            android:contentDescription="Planner menu" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRec"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="REC"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone"
            android:layout_marginStart="4dp"
            app:strokeWidth="0dp"
            app:strokeColor="#FFD600" />

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="&#x25B6;"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginEnd="4dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="&#x23F8;"
            android:backgroundTint="#F9A825"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:visibility="gone"
            android:layout_marginEnd="4dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />

        <Button
            android:id="@+id/btnEStop"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="E-STOP"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="12sp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />
    </LinearLayout>

    <!-- ── RC channel strip (PPM µs values from RP2040 via HM30 SBUS) ── -->
    <LinearLayout
        android:id="@+id/rcBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#55000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <TextView
            android:id="@+id/txtRcChannels"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RC: --"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ── Right-side map controls ────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/rcBar"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLayers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_mapmode"
            app:backgroundTint="#FFF"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="#FFF" />
    </LinearLayout>

    <!-- ── Dual rover HUD — pinned to bottom of screen ────────────────── -->
    <LinearLayout
        android:id="@+id/roverHud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC0D1117"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- RV1 card -->
        <LinearLayout
            android:id="@+id/rv1Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#22FF3333"
            android:orientation="vertical"
            android:padding="6dp"
            android:layout_marginEnd="3dp">

            <!-- Row 1: RV1 label + SBUS dot + HB dot + RTK badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RV1"
                    android:textColor="#FF4444"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SBUS"
                    android:textColor="#607D8B"
                    android:textSize="8sp"
                    android:layout_marginEnd="2dp" />

                <TextView
                    android:id="@+id/dotRv1Sbus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x25CF;"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HB"
                    android:textColor="#607D8B"
                    android:textSize="8sp"
                    android:layout_marginEnd="2dp" />

                <TextView
                    android:id="@+id/dotRv1Hb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x25CF;"
                    android:textColor="#888888"
                    android:textSize="10sp" />

                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <TextView
                    android:id="@+id/txtRv1Rtk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NO GPS"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:background="#33FFFFFF"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp" />
            </LinearLayout>

            <!-- Row 2: battery, temperature, tank -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <TextView
                    android:id="@+id/txtRv1Bat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BAT: --%"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txtRv1Temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TMP: --&#xB0;"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txtRv1Tank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TNK: --%"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- RV2 card -->
        <LinearLayout
            android:id="@+id/rv2Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#222244FF"
            android:orientation="vertical"
            android:padding="6dp"
            android:layout_marginStart="3dp">

            <!-- Row 1: RV2 label + RF dot + HB dot + RTK badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RV2"
                    android:textColor="#4488FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RF"
                    android:textColor="#607D8B"
                    android:textSize="8sp"
                    android:layout_marginEnd="2dp" />

                <TextView
                    android:id="@+id/dotRv2Rf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x25CF;"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HB"
                    android:textColor="#607D8B"
                    android:textSize="8sp"
                    android:layout_marginEnd="2dp" />

                <TextView
                    android:id="@+id/dotRv2Hb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x25CF;"
                    android:textColor="#888888"
                    android:textSize="10sp" />

                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <TextView
                    android:id="@+id/txtRv2Rtk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NO GPS"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:background="#33FFFFFF"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp" />
            </LinearLayout>

            <!-- Row 2: battery, temperature, tank -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <TextView
                    android:id="@+id/txtRv2Bat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BAT: --%"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txtRv2Temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TMP: --&#xB0;"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txtRv2Tank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TNK: --%"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
