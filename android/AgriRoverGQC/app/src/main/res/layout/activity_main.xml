<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/touchOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:visibility="gone" />

    <!-- ── Top status bar ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80000000"
        android:padding="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnModeMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODE: MANUAL"
            android:backgroundTint="#FF9800" />

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <Button
            android:id="@+id/btnEStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-STOP"
            android:backgroundTint="#FF0000"
            android:textStyle="bold" />

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <TextView
            android:id="@+id/txtConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="#FF9800"
            android:textSize="20sp"
            android:layout_marginEnd="8dp" />
        <TextView android:id="@+id/txtBattery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B: --%" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/txtTank"    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T: --%" android:textColor="#FFF" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/txtTemp"    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C: --°" android:textColor="#FFF"/>
    </LinearLayout>

    <!-- ── RC channel strip (PPM µs values from RP2040 via HM30 SBUS) ── -->
    <LinearLayout
        android:id="@+id/rcBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#55000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <TextView
            android:id="@+id/txtRcChannels"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RC: --"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ── Right-side map controls ────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/rcBar"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnLayers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_mapmode"
            app:backgroundTint="#FFF"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="#FFF" />
    </LinearLayout>

    <!-- ── Planner toolbar (bottom) ────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/plannerToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#AA000000"
        android:gravity="center"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/btnSave" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@android:drawable/ic_menu_save" android:layout_margin="5dp"/>
        <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/btnLoad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@android:drawable/ic_menu_upload" android:layout_margin="5dp"/>
        <Button android:id="@+id/btnRec" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏺ REC" android:backgroundTint="#F44336" android:layout_margin="5dp"/>
        <Button android:id="@+id/btnUpload" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UPLOAD" android:backgroundTint="#2196F3" android:layout_margin="5dp"/>
    </LinearLayout>

    <!-- ── Auto toolbar (bottom) ───────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/autoToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#AA000000"
        android:gravity="center"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button android:id="@+id/btnToggleR1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R1" android:backgroundTint="#F44336" android:layout_margin="5dp" android:minWidth="48dp"/>
        <Button android:id="@+id/btnToggleR2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R2" android:backgroundTint="#2196F3" android:layout_margin="5dp" android:minWidth="48dp"/>
        <Button android:id="@+id/btnStart" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="START" android:backgroundTint="#4CAF50" android:layout_margin="5dp"/>
        <Button android:id="@+id/btnStop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAUSE" android:backgroundTint="#FF9800" android:layout_margin="5dp"/>
        <Button android:id="@+id/btnClear" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CLEAR" android:layout_margin="5dp"/>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
