# NTRIP credentials for RTK corrections — copy to tools/.env.rtk and fill in.
# tools/.env.rtk is gitignored and never committed.

NTRIP_HOST=caster.emlid.com
NTRIP_PORT=2101
NTRIP_USER=your_username
NTRIP_PASS=your_password
NTRIP_MOUNT=your_mountpoint

# Approximate field coordinates (within ~5 km is fine — keeps Emlid connection alive)
APPROX_LAT=20.7277
APPROX_LON=-103.5668
